# =====================================================================
# Secrets obligatoires : sans ces 2 variables, le compose ne demarre pas
# =====================================================================

# Secret HMAC utilise pour signer les JWT (partage entre auth et api).
# Minimum 64 bytes pour HS512. Generer une valeur via :
#   openssl rand -base64 64
BETTER_AUTH_SECRET=

# Cle API Resend pour l'envoi des emails de verification et de reset.
# Une cle de demo est fournie ici pour permettre une evaluation immediate ;
# elle sera revoquee a l'issue de la soutenance.
# Pour un deploiement autonome, obtenir une cle sur https://resend.com/api-keys
RESEND_API_KEY=RESEND_KEY_PLACEHOLDER


# =====================================================================
# Overrides optionnels : les valeurs par defaut sont deja fixees dans le
# compose. Decommenter uniquement pour modifier.
# =====================================================================

# Mot de passe de la base healthai (metier)
# DB_PASSWORD=password

# Config de la base auth (better-auth)
# AUTH_DB_USER=root
# AUTH_DB_PASSWORD=password
# AUTH_DB_NAME=auth_db

# URL publique du service auth
# BETTER_AUTH_URL=http://localhost:3000

# Origine CORS autorisee par le service auth
# CORS_ORIGIN=http://localhost:5173

# Planification cron de l'ETL (format cron)
# CRON_SCHEDULE=0 2 * * *

# Nom de la base Mongo pour reco-fitness
# MONGO_DATABASE=reco_fitness

# =====================================================================
# IA generative (ai-nutrition) : optionnel
# Sans configuration, le service utilise Ollama (gemma3:4b) en local.
# =====================================================================

# Backend LLM par defaut. "ollama" pour la demo autonome, "mistral" si la
# cle ci-dessous est renseignee. Le toggle UI (Parametres) reste prioritaire.
# DEFAULT_LLM=ollama

# Cle API Mistral pour activer le provider manage (latence ~2s vs ~60s Ollama).
# Obtenir une cle sur https://console.mistral.ai/api-keys. Le service fonctionne
# sans cette cle : il bascule automatiquement sur Ollama.
# MISTRAL_API_KEY=
