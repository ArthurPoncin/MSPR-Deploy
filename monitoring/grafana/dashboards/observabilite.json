{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cibles UP",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(up)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cibles DOWN",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(up == 0) or vector(0)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Erreurs logs /s",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(rate({container=~\"mspr-.*\"} |~ \"(?i)(error|exception|traceback|fatal|panic)\" [5m]))", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Lignes de log /s (total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum(rate({container=~\"mspr-.*\"}[5m]))", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "fieldConfig": {
        "defaults": { "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Debit HTTP par service (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (job) (rate(http_requests_total[5m]))", "legendFormat": "{{job}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(rate(http_server_requests_seconds_count[5m]))", "legendFormat": "api (spring)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latence HTTP p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{job}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "api (spring)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Erreurs HTTP 5xx /s par service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{job}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))", "legendFormat": "api (spring)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 }, "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Erreurs dans les logs par conteneur (/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (container) (rate({container=~\"mspr-.*\"} |~ \"(?i)(error|exception|traceback|fatal|panic)\" [5m]))", "legendFormat": "{{container}}", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1 } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Volume de logs par conteneur (/s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "sum by (container) (rate({container=~\"$container\"}[5m]))", "legendFormat": "{{container}}", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Logs (filtre conteneur + recherche)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "{container=~\"$container\"} |~ \"(?i)$search\"", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true, "dedupStrategy": "none" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mspr", "healthai", "observabilite"],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "container",
        "label": "Conteneur",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(container)",
        "regex": "/^mspr-.*/",
        "includeAll": true,
        "multi": true,
        "allValue": "mspr-.*",
        "current": { "text": ["All"], "value": ["$__all"] },
        "refresh": 1,
        "sort": 1
      },
      {
        "type": "textbox",
        "name": "search",
        "label": "Recherche logs",
        "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "MSPR HealthAI - Observabilite (logs + metriques)",
  "uid": "mspr-observabilite",
  "version": 1
}
