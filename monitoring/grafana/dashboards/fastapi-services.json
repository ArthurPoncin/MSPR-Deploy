      "title": "Memoire residente (process)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "process_resident_memory_bytes{job=\"$job\"}", "legendFormat": "rss", "datasource": { "type": "prometheus", "uid": "prometheus" } }
